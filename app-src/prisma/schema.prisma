generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Link {
  id          String   @id @default(cuid())
  slug        String   @unique
  originalUrl String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  clicks      Click[]

  @@index([slug])
}

model Click {
  id        String   @id @default(cuid())
  linkId    String
  link      Link     @relation(fields: [linkId], references: [id], onDelete: Cascade)
  browser   String?
  os        String?
  device    String?
  country   String?
  referrer  String?
  ip        String?
  createdAt DateTime @default(now())

  @@index([linkId])
  @@index([createdAt])
}

model LoginAttempt {
  id            String   @id @default(cuid())
  ip            String
  patternFails  Int      @default(0)
  passwordFails Int      @default(0)
  updatedAt     DateTime @updatedAt

  @@unique([ip])
}
